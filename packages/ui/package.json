{
  "name": "@stagecast/ui",
  "version": "0.1.0",
  "private": true,
  "description": "stagecast 共有 UI パッケージ (shadcn primitives + デザイントークン + 放送機材ライク components)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./tokens.css": "./src/tokens.css",
    "./tailwind-preset": {
      "types": "./src/tailwind-preset.ts",
      "import": "./src/tailwind-preset.ts"
    },
    "./icons": {
      "types": "./src/icons/index.ts",
      "import": "./src/icons/index.ts"
    }
  },
  "scripts": {
    "dev": "vp dev",
    "build": "tsc --noEmit",
