# ============================================================================
# Stagecast 環境変数テンプレート
# 実値はコミットしないこと。本番は Secrets Manager / SSM パラメータストアから注入する
# (T7, ADR D-10)。ローカルでは本ファイルを .env にコピーして使う。
# ============================================================================

# --- AWS ---
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=000000000000

# --- 制御層 (control-api, T5) ---
# CDK デプロイ後に Output から取得して埋める。
METADATA_TABLE_NAME=
ASSETS_BUCKET_NAME=
# Lambda 内では Secrets Manager から取得 (INVITE_TOKEN_SECRET_ARN)。
# ローカル/テストでは plain 値で OK。
INVITE_TOKEN_SECRET=dev-insecure-secret
INVITE_TOKEN_SECRET_ARN=
INVITE_BASE_URL=http://localhost:5174/join

# --- Cognito (管理者認証 / Hosted UI, T6) ---
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=

# --- LiveKit (SFU / Egress, T1 / T2) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SECRET_ARN=
# 字幕ワーカーが入室するルーム (eventId と一致させる)。
LIVEKIT_ROOM=
LIVEKIT_INGEST_TOKEN=

# --- 共有状態 / 字幕バス (T3) ---
# VALKEY_URL は redis:// プレフィックス可。VALKEY_ENDPOINT はホスト名のみ (EventMediaStack 出力)。
VALKEY_URL=redis://localhost:6379
VALKEY_ENDPOINT=
# CAPTION_BUS=valkey で ValkeyStreamsCaptionBus に切替 (デフォルトは InProcess)。
CAPTION_BUS=

# --- 字幕パイプライン ---
# 常用経路: Amazon Transcribe Streaming + Amazon Translate
# 品質経路: LLM (Bedrock)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
CAPTION_ENGINE=transcribe
CAPTION_SOURCE_LANGUAGE=ja
CAPTION_LANGUAGES=ja,en
YOUTUBE_CAPTION_LANGUAGE=ja
CUSTOM_CAPTION_API=false
CAPTION_WS_PORT=8080
CAPTIONS_BUCKET_NAME=

# --- YouTube Live ---
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_INGESTION_URL=

# --- 開発フラグ ---
# 外部依存をフェイクに切替 (テスト/ローカルで外部接続なしに動かす)
USE_FAKE_ADAPTERS=true

# --- フロント (Vite ビルド時に注入) ---
# admin-web / stage-web は build 時の環境変数を VITE_* 形式で読む。
VITE_CONTROL_API_URL=
VITE_COGNITO_DOMAIN=
VITE_COGNITO_USER_POOL_CLIENT_ID=

# --- 統合テスト (T8) ---
# RUN_INTEGRATION=1 のときのみ *.integration.test.ts が実 AWS を叩く。
RUN_INTEGRATION=
COGNITO_ID_TOKEN=
