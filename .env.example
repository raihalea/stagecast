# ============================================================================
# Stagecast 環境変数テンプレート
# 実値はコミットしないこと。実行時は環境変数 / SSM パラメータストア /
# Secrets Manager から注入する（PROMPT 共通ルール / DESIGN.md, ADR D-10）。
# ローカルでは本ファイルを .env にコピーして使う。
# ============================================================================

# --- AWS ---
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=000000000000

# --- 制御層 (control-api) ---
# DynamoDB テーブル名・S3 バケット名は CDK デプロイ時に注入される想定
EVENTS_TABLE_NAME=stagecast-events
ASSETS_BUCKET_NAME=stagecast-assets
# 招待トークン署名用の HMAC シークレット（本番は Secrets Manager）
INVITE_TOKEN_SECRET=replace-me-with-a-long-random-secret

# --- Cognito (管理者認証) ---
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=

# --- LiveKit (SFU / Egress) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- 共有状態 (ElastiCache for Valkey) ---
VALKEY_URL=redis://localhost:6379

# --- 字幕パイプライン ---
# 常用経路: Amazon Transcribe Streaming + Amazon Translate（AWS 資格情報を使用）
# 品質経路: LLM (Bedrock)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- YouTube Live API ---
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# --- ローカル開発フラグ ---
# 外部依存をフェイク実装に切り替える（テスト/ローカルで外部接続なしに動かす）
USE_FAKE_ADAPTERS=true
